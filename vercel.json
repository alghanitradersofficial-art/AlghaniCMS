{
  "version": 2,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm run build",
  "outputDirectory": "artifacts/erp/dist",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/erp/vite.config.ts",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "artifacts/erp/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/erp/dist/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
