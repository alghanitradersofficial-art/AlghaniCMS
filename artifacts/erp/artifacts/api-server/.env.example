# Database (Neon Postgres connection string)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# JWT (use a random 64-char string in production)
JWT_SECRET=your-random-secret-here-min-32-chars

# Groq AI (free at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# Frontend deployment origin (required in production for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CEO_EMAIL=

NODE_ENV=production
