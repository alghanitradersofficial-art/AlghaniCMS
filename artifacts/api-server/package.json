{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "pnpm --filter @workspace/api-zod --filter @workspace/db run build && node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.23",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "groq-sdk": "^1.3.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "node-telegram-bot-api": "^1.1.2",
    "nodemailer": "^9.0.3",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.15",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
