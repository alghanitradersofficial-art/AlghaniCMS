{
  "name": "alghani-cms",
  "version": "1.0.0",
  "private": true,
  "description": "Al Ghani Wholesale Traders ERP System",
  "scripts": {
    "dev": "pnpm --filter @workspace/api-server run dev",
    "build": "pnpm run build:db && pnpm run build:api && pnpm run build:erp",
    "build:db": "pnpm --filter @workspace/db run build",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "build:erp": "pnpm --filter @workspace/erp run build",
    "migrate": "node scripts/migrate.mjs",
    "seed": "node scripts/seed-admin.mjs",
    "start": "node artifacts/api-server/dist/index.mjs"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
